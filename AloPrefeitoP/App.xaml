<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="AloPrefeitoP.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:AloPrefeitoP.Converters"
    xmlns:local="clr-namespace:AloPrefeitoP">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:PasswordEyeIconConverter x:Key="PasswordEyeIconConverter" />
            <conv:ChatBubbleAlignConverter x:Key="ChatBubbleAlignConverter" />
            <conv:ChatBubbleColorConverter x:Key="ChatBubbleColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
