<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="20" Spacing="12">
        <Label FontSize="18" Text="Transcrição:" />
        <Label
            x:Name="ResultLabel"
            FontSize="16"
            Text="(a transcrição vai aparecer aqui)" />

        <Button
            BackgroundColor="LightBlue"
            Clicked="OnStartClicked"
            Text="🎙️ Começar a ouvir"
            TextColor="White" />

        <Button
            BackgroundColor="red"
            Clicked="OnStopClicked"
            Text="⏹Parar"
            TextColor="white" />
    </VerticalStackLayout>
</ContentPage>
