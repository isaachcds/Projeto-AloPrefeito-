<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.AlterarSenhaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    BackgroundColor="White"
    BackgroundImageSource="iagestor360_2.png"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout
            Padding="34,0,34,-104"
            HorizontalOptions="Center"
            Spacing="10"
            TranslationY="58"
            VerticalOptions="Center">

            <Label
                FontAttributes="Bold"
                FontSize="16"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Alterar senha"
                TextColor="Black" />

            <dx:DXBorder
                Padding="14"
                BackgroundColor="#F4F4F4"
                CornerRadius="10"
                HorizontalOptions="Center"
                WidthRequest="250">

                <VerticalStackLayout Spacing="10">

                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontSize="12"
                            Text="Nova senha"
                            TextColor="#2A2A2A" />

                        <Grid ColumnDefinitions="*,Auto">
                            <dx:DXBorder
                                Grid.ColumnSpan="2"
                                Padding="10,5"
                                BackgroundColor="#EFEFEF"
                                BorderColor="#D6D6D6"
                                BorderThickness="1"
                                CornerRadius="6">

                                <Entry
                                    Margin="0,0,28,0"
                                    BackgroundColor="Transparent"
                                    FontSize="12"
                                    HeightRequest="34"
                                    IsPassword="{Binding NovaSenhaVisivel, Converter={StaticResource InverseBoolConverter}}"
                                    Placeholder="Digite sua nova senha"
                                    PlaceholderColor="#8C8C8C"
                                    Text="{Binding NovaSenha}"
                                    TextColor="#222222" />
                            </dx:DXBorder>

                            <ImageButton
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                Padding="0"
                                BackgroundColor="Transparent"
                                Command="{Binding AlternarNovaSenhaCommand}"
                                HeightRequest="20"
                                HorizontalOptions="End"
                                Source="{Binding NovaSenhaVisivel, Converter={StaticResource PasswordEyeIconConverter}}"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontSize="12"
                            Text="Confirmar senha"
                            TextColor="#2A2A2A" />

                        <Grid ColumnDefinitions="*,Auto">
                            <dx:DXBorder
                                Grid.ColumnSpan="2"
                                Padding="10,5"
                                BackgroundColor="#EFEFEF"
                                BorderColor="#D6D6D6"
                                BorderThickness="1"
                                CornerRadius="6">

                                <Entry
                                    Margin="0,0,28,0"
                                    BackgroundColor="Transparent"
                                    FontSize="12"
                                    HeightRequest="34"
                                    IsPassword="{Binding ConfirmarSenhaVisivel, Converter={StaticResource InverseBoolConverter}}"
                                    Placeholder="Confirme sua senha"
                                    PlaceholderColor="#8C8C8C"
                                    Text="{Binding ConfirmarSenha}"
                                    TextColor="#222222" />
                            </dx:DXBorder>

                            <ImageButton
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                Padding="0"
                                BackgroundColor="Transparent"
                                Command="{Binding AlternarConfirmarSenhaCommand}"
                                HeightRequest="20"
                                HorizontalOptions="End"
                                Source="{Binding ConfirmarSenhaVisivel, Converter={StaticResource PasswordEyeIconConverter}}"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                        </Grid>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button
                            Grid.Column="0"
                            BackgroundColor="Transparent"
                            BorderColor="#999999"
                            BorderWidth="1"
                            Command="{Binding VoltarCommand}"
                            CornerRadius="6"
                            FontSize="12"
                            HeightRequest="36"
                            Text="Cancelar"
                            TextColor="#333333" />

                        <Button
                            Grid.Column="1"
                            BackgroundColor="#2F2F32"
                            Command="{Binding SalvarCommand}"
                            CornerRadius="6"
                            FontSize="12"
                            HeightRequest="36"
                            Text="Salvar"
                            TextColor="White" />
                    </Grid>

                </VerticalStackLayout>
            </dx:DXBorder>
        </VerticalStackLayout>
    </Grid>
</ContentPage>