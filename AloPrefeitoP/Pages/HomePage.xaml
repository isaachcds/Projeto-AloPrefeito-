<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:lottie="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    Title="Início"
    BackgroundColor="WhiteSmoke">

    <Grid
        Padding="22"
        RowDefinitions="Auto,*,Auto,Auto"
        RowSpacing="12">

        <!--  HEADER  -->
        <VerticalStackLayout
            x:Name="HeaderBoasVindas"
            Grid.Row="0"
            Margin="0,8,0,0"
            IsVisible="{Binding TemMensagens, Converter={StaticResource InverseBoolConverter}}"
            Spacing="4">
            <Label
                FontSize="16"
                Text="{Binding Nome, StringFormat='Olá, {0}'}"
                TextColor="#1B1B1B" />
            <Label
                FontSize="16"
                Text="Como posso lhe ajudar hoje?"
                TextColor="#1B1B1B" />
        </VerticalStackLayout>

        <!--  MEIO  -->
        <Grid
            Grid.Row="1"
            RowDefinitions="*,Auto,Auto,Auto"
            RowSpacing="14">

            <!--  LISTA DO CHAT  -->
            <CollectionView
                x:Name="ChatList"
                Grid.Row="0"
                ItemsSource="{Binding ListaMensagens}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Frame
                                Margin="0,6"
                                Padding="12"
                                BackgroundColor="{Binding IsBot, Converter={StaticResource ChatBubbleColorConverter}}"
                                CornerRadius="14"
                                HasShadow="False"
                                HorizontalOptions="{Binding IsBot, Converter={StaticResource ChatBubbleAlignConverter}}">
                                <Label
                                    FontSize="14"
                                    Text="{Binding Mensagem}"
                                    TextColor="#1B1B1B" />
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!--  IA está digitando  -->
            <dx:DXBorder
                Grid.Row="1"
                Padding="12,8"
                BackgroundColor="White"
                CornerRadius="14"
                HorizontalOptions="Start"
                IsVisible="{Binding IaEstaDigitando}">
                <Label
                    FontSize="13"
                    Text="Alô Prefeito está digitando..."
                    TextColor="#6F6F6F" />
            </dx:DXBorder>

            <!--  TRANSCRIÇÃO  -->
            <dx:DXBorder
                Grid.Row="2"
                Padding="12,10"
                BackgroundColor="#EAF7F7"
                CornerRadius="14"
                HorizontalOptions="Fill"
                IsVisible="{Binding EstaEscutando}">
                <Label
                    FontSize="14"
                    Text="{Binding TextoFalado}"
                    TextColor="#1B1B1B" />
            </dx:DXBorder>

            <!--  MICROFONE GRANDE: só antes do chat começar  -->
            <dx:DXBorder
                Grid.Row="3"
                Padding="0"
                BackgroundColor="#6D74E6"
                CornerRadius="85"
                HeightRequest="170"
                HorizontalOptions="Center"
                IsVisible="{Binding TemMensagens, Converter={StaticResource InverseBoolConverter}}"
                VerticalOptions="Center"
                WidthRequest="170">
                <Grid>
                    <lottie:SKLottieView
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        IsAnimationEnabled="{Binding EstaEscutando}"
                        RepeatCount="-1"
                        Source="microphone.json"
                        VerticalOptions="Center"
                        WidthRequest="120">
                        <lottie:SKLottieView.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleEscutaCommand}" />
                        </lottie:SKLottieView.GestureRecognizers>
                    </lottie:SKLottieView>
                </Grid>
            </dx:DXBorder>

        </Grid>

        <!--  INPUT: só aparece quando NÃO está escutando  -->
        <Grid
            Grid.Row="2"
            Margin="0,0,0,0"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10"
            IsVisible="{Binding NaoEstaEscutando}">

            <dx:DXBorder
                Grid.Column="0"
                Padding="14,10"
                BackgroundColor="#E7E7E7"
                CornerRadius="14">
                <Entry
                    BackgroundColor="Transparent"
                    FontSize="14"
                    Placeholder="Digite sua mensagem..."
                    PlaceholderColor="#6F6F6F"
                    ReturnCommand="{Binding EnviarTextoCommand}"
                    ReturnType="Send"
                    Text="{Binding MensagemDigitada}"
                    TextColor="#1B1B1B" />
            </dx:DXBorder>

            <dx:DXBorder
                Grid.Column="1"
                BackgroundColor="#6D74E6"
                CornerRadius="20"
                HeightRequest="40"
                HorizontalOptions="End"
                VerticalOptions="Center"
                WidthRequest="40">

                <Grid>
                    <Image
                        HeightRequest="18"
                        HorizontalOptions="Center"
                        Source="send.png"
                        VerticalOptions="Center"
                        WidthRequest="18" />

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EnviarTextoCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

            </dx:DXBorder>

        </Grid>

        <!--  MICROFONE PEQUENO: continua visível mesmo escutando  -->
        <dx:DXBorder
            Grid.Row="3"
            Margin="0,0,0,14"
            BackgroundColor="#6D74E6"
            CornerRadius="42"
            HeightRequest="84"
            HorizontalOptions="Center"
            IsVisible="{Binding TemMensagens}"
            WidthRequest="84">
            <Grid>
                <lottie:SKLottieView
                    HeightRequest="56"
                    HorizontalOptions="Center"
                    IsAnimationEnabled="{Binding EstaEscutando}"
                    RepeatCount="-1"
                    Source="microphone.json"
                    VerticalOptions="Center"
                    WidthRequest="56">
                    <lottie:SKLottieView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleEscutaCommand}" />
                    </lottie:SKLottieView.GestureRecognizers>
                </lottie:SKLottieView>
            </Grid>
        </dx:DXBorder>

    </Grid>
</ContentPage>