<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:lottie="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    BackgroundColor="WhiteSmoke">

    <Grid
        Padding="22"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="0">

        <!--  HEADER (some quando está escutando)  -->
        <VerticalStackLayout
            Grid.Row="0"
            Margin="0,8,0,0"
            IsVisible="{Binding NaoEstaEscutando}"
            Spacing="4">
            <Label
                FontSize="16"
                Text="{Binding Nome, StringFormat='Olá, {0}'}"
                TextColor="#1B1B1B" />
            <Label
                FontSize="16"
                Text="Como posso lhe ajudar hoje?"
                TextColor="#1B1B1B" />
        </VerticalStackLayout>

        <!--  MEIO: transcrição + microfone  -->
        <Grid
            Grid.Row="1"
            RowDefinitions="Auto,*"
            RowSpacing="18">

            <!--  balão de transcrição (aparece enquanto escuta com "..." e depois com texto)  -->
            <dx:DXBorder
                Grid.Row="0"
                Padding="12,10"
                BackgroundColor="#EAF7F7"
                CornerRadius="14"
                HorizontalOptions="Fill"
                IsVisible="{Binding TemTranscricao}">
                <Label
                    FontSize="14"
                    Text="{Binding TextoTranscricaoUI}"
                    TextColor="#1B1B1B" />
            </dx:DXBorder>

            <!--  microfone  -->
            <dx:DXBorder
                Grid.Row="1"
                Padding="0"
                BackgroundColor="#6D74E6"
                CornerRadius="85"
                HeightRequest="170"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="170">
                <Grid>
                    <lottie:SKLottieView
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        IsAnimationEnabled="{Binding EstaEscutando}"
                        RepeatCount="-1"
                        Source="microphone.json"
                        VerticalOptions="Center"
                        WidthRequest="120">
                        <lottie:SKLottieView.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleEscutaCommand}" />
                        </lottie:SKLottieView.GestureRecognizers>
                    </lottie:SKLottieView>
                </Grid>
            </dx:DXBorder>

        </Grid>

        <!--  INPUT (some quando está escutando)  -->
        <Grid
            Grid.Row="2"
            Margin="0,0,0,14"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10"
            IsVisible="{Binding NaoEstaEscutando}">

            <dx:DXBorder
                Grid.Column="0"
                Padding="14,10"
                BackgroundColor="#E7E7E7"
                CornerRadius="14">

                <Entry
                    BackgroundColor="Transparent"
                    FontSize="14"
                    Placeholder="Digite sua mensagem..."
                    PlaceholderColor="#6F6F6F"
                    Text="{Binding MensagemDigitada}"
                    TextColor="#1B1B1B" />
            </dx:DXBorder>

            <!--  Botãozinho do lado (igual sua bolinha)  -->
            <dx:DXBorder
                Grid.Column="1"
                BackgroundColor="#6D74E6"
                CornerRadius="20"
                HeightRequest="40"
                HorizontalOptions="End"
                VerticalOptions="Center"
                WidthRequest="40">
                <Label
                    FontAttributes="Bold"
                    HorizontalTextAlignment="Center"
                    Text="i"
                    TextColor="White"
                    VerticalTextAlignment="Center" />
            </dx:DXBorder>

        </Grid>

    </Grid>
</ContentPage>