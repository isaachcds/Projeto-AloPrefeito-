<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AloPrefeitoP.Models"
    x:Name="HomeRoot"
    BackgroundColor="#F4F4F4">

    <Grid>

        <!-- CONTEÚDO PRINCIPAL -->
        <Grid
            Padding="18,26,18,18"
            RowDefinitions="Auto,*,Auto"
            RowSpacing="18">

            <!-- TOPO -->
            <dx:DXBorder
                Grid.Row="0"
                Padding="14,10"
                BackgroundColor="#8EC1D8"
                CornerRadius="18">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <!-- MENU -->
                    <Grid
                        Grid.Column="0"
                        HeightRequest="36"
                        WidthRequest="36"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                        <Label
                            FontSize="20"
                            HorizontalOptions="Center"
                            Text="☰"
                            TextColor="#1B1B1B"
                            VerticalOptions="Center" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AlternarMenuCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- RESPOSTAS EM ÁUDIO -->
                    <dx:DXBorder
                        Grid.Column="1"
                        Padding="10,6"
                        BackgroundColor="White"
                        CornerRadius="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <HorizontalStackLayout
                            Spacing="8"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="16"
                                Source="{Binding AudioIcon}"
                                VerticalOptions="Center"
                                WidthRequest="16" />

                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="Respostas em áudio"
                                TextColor="#2D2D2D"
                                VerticalOptions="Center" />

                            <Switch
                                IsToggled="{Binding Fala}"
                                OnColor="#32D46B"
                                Scale="0.85"
                                ThumbColor="White"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </dx:DXBorder>

                    <!-- PERFIL -->
                    <dx:DXBorder
                        Grid.Column="2"
                        Padding="0"
                        BackgroundColor="#CFC8E8"
                        CornerRadius="18"
                        HeightRequest="36"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        WidthRequest="36">
                        <Grid>
                            <Image
                                HeightRequest="18"
                                HorizontalOptions="Center"
                                Source="profile_icon.svg"
                                VerticalOptions="Center"
                                WidthRequest="18" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AbrirPerfilCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </dx:DXBorder>

                </Grid>
            </dx:DXBorder>

            <!-- ÁREA CENTRAL -->
            <Grid
                Grid.Row="1"
                RowDefinitions="*,Auto,Auto"
                RowSpacing="14">

                <!-- ESTADO INICIAL -->
                <Grid
                    Grid.Row="0"
                    IsVisible="{Binding TemMensagens, Converter={StaticResource InverseBoolConverter}}">

                    <VerticalStackLayout
                        x:Name="HeaderBoasVindas"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="6">

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalTextAlignment="Center"
                            Text="{Binding Nome, StringFormat='Olá, {0}!'}"
                            TextColor="#111111" />

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalTextAlignment="Center"
                            Text="Como posso te ajudar hoje?"
                            TextColor="#111111" />
                    </VerticalStackLayout>
                </Grid>

                <!-- CHAT -->
                <CollectionView
                    x:Name="ChatList"
                    Grid.Row="0"
                    IsVisible="{Binding TemMensagens}"
                    ItemsSource="{Binding ListaMensagens}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,4">
                                <Frame
                                    Padding="12"
                                    BackgroundColor="{Binding IsBot, Converter={StaticResource ChatBubbleColorConverter}}"
                                    CornerRadius="16"
                                    HasShadow="False"
                                    HorizontalOptions="{Binding IsBot, Converter={StaticResource ChatBubbleAlignConverter}}"
                                    MaximumWidthRequest="280">
                                    <Label
                                        FontSize="14"
                                        Text="{Binding Mensagem}"
                                        TextColor="#1B1B1B" />
                                </Frame>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- IA DIGITANDO -->
                <dx:DXBorder
                    Grid.Row="1"
                    Padding="12,8"
                    BackgroundColor="White"
                    CornerRadius="14"
                    HorizontalOptions="Start"
                    IsVisible="{Binding IaEstaDigitando}">
                    <Label
                        FontSize="13"
                        Text="Alô Prefeito está digitando..."
                        TextColor="#6F6F6F" />
                </dx:DXBorder>

                <!-- TRANSCRIÇÃO -->
                <dx:DXBorder
                    Grid.Row="2"
                    Padding="12,10"
                    BackgroundColor="#EAF7F7"
                    CornerRadius="14"
                    HorizontalOptions="Fill"
                    IsVisible="{Binding EstaEscutando}">
                    <Label
                        FontSize="14"
                        Text="{Binding TextoFalado}"
                        TextColor="#1B1B1B" />
                </dx:DXBorder>
            </Grid>

            <!-- BARRA INFERIOR -->
            <dx:DXBorder
                Grid.Row="2"
                Margin="6,0,6,6"
                Padding="10,8"
                BackgroundColor="#8EC1D8"
                CornerRadius="18"
                HorizontalOptions="Fill">

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

                    <!-- MODO NORMAL -->
                    <Grid
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        IsVisible="{Binding NaoEstaEscutando}">
                        <Entry
                            BackgroundColor="Transparent"
                            FontSize="14"
                            Placeholder="Digite sua mensagem..."
                            PlaceholderColor="#4C4C4C"
                            ReturnCommand="{Binding EnviarTextoCommand}"
                            ReturnType="Send"
                            Text="{Binding MensagemDigitada}"
                            TextColor="#111111"
                            VerticalOptions="Center" />
                    </Grid>

                    <!-- MODO GRAVAÇÃO -->
                    <Grid
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        IsVisible="{Binding EstaEscutando}"
                        ColumnDefinitions="*"
                        VerticalOptions="Center">

                        <Grid
                            x:Name="WaveGrid"
                            ColumnSpacing="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center">

                            <BoxView x:Name="Wave1"  Grid.Column="0"  WidthRequest="2" HeightRequest="10" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave2"  Grid.Column="1"  WidthRequest="2" HeightRequest="18" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave3"  Grid.Column="2"  WidthRequest="2" HeightRequest="12" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave4"  Grid.Column="3"  WidthRequest="2" HeightRequest="22" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave5"  Grid.Column="4"  WidthRequest="2" HeightRequest="9"  Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave6"  Grid.Column="5"  WidthRequest="2" HeightRequest="16" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave7"  Grid.Column="6"  WidthRequest="2" HeightRequest="11" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave8"  Grid.Column="7"  WidthRequest="2" HeightRequest="20" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave9"  Grid.Column="8"  WidthRequest="2" HeightRequest="10" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave10" Grid.Column="9"  WidthRequest="2" HeightRequest="17" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave11" Grid.Column="10" WidthRequest="2" HeightRequest="13" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave12" Grid.Column="11" WidthRequest="2" HeightRequest="19" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave13" Grid.Column="12" WidthRequest="2" HeightRequest="9"  Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave14" Grid.Column="13" WidthRequest="2" HeightRequest="15" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave15" Grid.Column="14" WidthRequest="2" HeightRequest="11" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave16" Grid.Column="15" WidthRequest="2" HeightRequest="21" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave17" Grid.Column="16" WidthRequest="2" HeightRequest="10" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave18" Grid.Column="17" WidthRequest="2" HeightRequest="18" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave19" Grid.Column="18" WidthRequest="2" HeightRequest="12" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave20" Grid.Column="19" WidthRequest="2" HeightRequest="22" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave21" Grid.Column="20" WidthRequest="2" HeightRequest="9"  Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave22" Grid.Column="21" WidthRequest="2" HeightRequest="16" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave23" Grid.Column="22" WidthRequest="2" HeightRequest="11" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
                            <BoxView x:Name="Wave24" Grid.Column="23" WidthRequest="2" HeightRequest="20" Color="#111111" CornerRadius="2" HorizontalOptions="Center" VerticalOptions="Center" />
             
                        </Grid>
                    </Grid>

                    <!-- MICROFONE -->
                    <dx:DXBorder
                        Grid.Column="1"
                        Padding="0"
                        BackgroundColor="{Binding MicrofoneBackground}"
                        CornerRadius="15"
                        HeightRequest="30"
                        WidthRequest="30"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Grid>
                            <Image
                                HeightRequest="16"
                                WidthRequest="16"
                                Source="{Binding MicrofoneIcon}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleEscutaManualCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </dx:DXBorder>

                    <!-- ENVIAR -->
                    <dx:DXBorder
                        Grid.Column="2"
                        Padding="0"
                        BackgroundColor="{Binding SendButtonBackground}"
                        CornerRadius="15"
                        HeightRequest="30"
                        WidthRequest="30"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="{Binding NaoEstaEscutando}">
                        <Grid>
                            <Image
                                HeightRequest="16"
                                WidthRequest="16"
                                Source="send_icon.svg"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnviarTextoCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </dx:DXBorder>

                </Grid>
            </dx:DXBorder>
        </Grid>

        <!-- OVERLAY -->
        <Grid
            x:Name="OverlayMenu"
            BackgroundColor="#80000000"
            InputTransparent="True"
            IsVisible="False"
            Opacity="0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OverlayMenu_Tapped" />
            </Grid.GestureRecognizers>
        </Grid>

        <!-- MENU -->
        <Grid
            x:Name="MenuLateral"
            BackgroundColor="#F5F5F7"
            HorizontalOptions="Start"
            TranslationX="-320"
            WidthRequest="320"
            ZIndex="10">

            <Grid
                Padding="20,22,20,16"
                RowDefinitions="Auto,Auto,Auto,*,Auto"
                RowSpacing="14">

                <VerticalStackLayout Grid.Row="0" Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="24"
                        Text="Histórico"
                        TextColor="#1B1B1B" />
                    <Label
                        FontSize="13"
                        Text="Acesse conversas anteriores ou inicie um novo chat."
                        TextColor="#6F6F6F" />
                </VerticalStackLayout>

                <dx:DXButton
                    Grid.Row="1"
                    ButtonType="Accent"
                    Command="{Binding NovoChatCommand}"
                    Content="Novo chat"
                    HeightRequest="50" />

                <dx:DXBorder
                    Grid.Row="2"
                    Padding="14,12"
                    BackgroundColor="White"
                    CornerRadius="16">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label
                            Grid.Column="0"
                            FontSize="16"
                            Text="🔍"
                            VerticalOptions="Center" />

                        <Label
                            Grid.Column="1"
                            FontSize="14"
                            Text="Pesquisar conversas"
                            TextColor="#8A8A8A"
                            VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrParaBuscaCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </dx:DXBorder>

                <Grid
                    Grid.Row="3"
                    RowDefinitions="*,Auto"
                    RowSpacing="8">

                    <CollectionView
                        Grid.Row="0"
                        ItemsSource="{Binding Chats}"
                        SelectionMode="None"
                        VerticalScrollBarVisibility="Never">

                        <CollectionView.EmptyView>
                            <VerticalStackLayout
                                Padding="20,40"
                                HorizontalOptions="Center"
                                Spacing="10"
                                VerticalOptions="Center">
                                <Label
                                    FontSize="18"
                                    HorizontalTextAlignment="Center"
                                    Text="💬" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    HorizontalTextAlignment="Center"
                                    Text="Nenhuma conversa ainda"
                                    TextColor="#1B1B1B" />
                                <Label
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="Quando você iniciar um chat, ele aparecerá aqui."
                                    TextColor="#6F6F6F" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ChatResumo">
                                <Grid Margin="0,0,0,12">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference HomeRoot}, Path=BindingContext.AbrirChatCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <dx:DXBorder
                                        Padding="14"
                                        BackgroundColor="White"
                                        CornerRadius="18">

                                        <Grid
                                            ColumnDefinitions="Auto,*"
                                            ColumnSpacing="12"
                                            RowDefinitions="Auto,Auto">

                                            <dx:DXBorder
                                                Grid.RowSpan="2"
                                                BackgroundColor="#6D74E6"
                                                CornerRadius="5"
                                                HeightRequest="10"
                                                VerticalOptions="Center"
                                                WidthRequest="10" />

                                            <Label
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                FontAttributes="Bold"
                                                FontSize="14"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="1"
                                                Text="{Binding Titulo}"
                                                TextColor="#1B1B1B" />

                                            <Label
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                FontSize="12"
                                                Text="Toque para abrir esta conversa"
                                                TextColor="#6F6F6F" />
                                        </Grid>
                                    </dx:DXBorder>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <dx:DXButton
                        Grid.Row="1"
                        ButtonType="Text"
                        Command="{Binding IrParaHistoricoCommand}"
                        Content="Ver mais"
                        HorizontalOptions="End"
                        IsVisible="{Binding TemMaisDeTresChats}" />
                </Grid>

                <Grid
                    Grid.Row="4"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="10"
                    VerticalOptions="End">

                    <dx:DXButton
                        Grid.Column="0"
                        ButtonType="Text"
                        Command="{Binding AbrirConfiguracoesCommand}"
                        Content="Configurações"
                        HorizontalOptions="Start"
                        Icon="settings_icon.svg"
                        IconHeight="18"
                        IconIndent="10"
                        IconWidth="18" />

                    <dx:DXButton
                        Grid.Column="1"
                        ButtonType="ToolButton"
                        Command="{Binding ConfirmarLogoffCommand}"
                        HeightRequest="44"
                        HorizontalOptions="End"
                        Icon="logoff_icon.svg"
                        IconHeight="18"
                        IconWidth="18"
                        ShowContent="False"
                        WidthRequest="44" />
                </Grid>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>