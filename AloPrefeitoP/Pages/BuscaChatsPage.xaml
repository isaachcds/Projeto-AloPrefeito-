<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.BuscaChatsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AloPrefeitoP.Models"
    x:Name="BuscaRoot"
    BackgroundColor="#F5F5F7"
    Shell.NavBarIsVisible="False">

    <Grid
        Padding="20,18"
        RowDefinitions="Auto,Auto,Auto,*"
        RowSpacing="14">

        <!--  TOPO  -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="12">
            <dx:DXBorder
                Padding="10"
                BackgroundColor="White"
                CornerRadius="14"
                HeightRequest="44"
                WidthRequest="44">
                <Grid>
                    <Label
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="←"
                        TextColor="#1B1B1B"
                        VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VoltarCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </dx:DXBorder>

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="22"
                Text="Buscar conversas"
                TextColor="#1B1B1B"
                VerticalOptions="Center" />
        </Grid>

        <!--  CAMPO  -->
        <dx:DXBorder
            Grid.Row="1"
            Padding="14,10"
            BackgroundColor="White"
            CornerRadius="16">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label
                    Grid.Column="0"
                    FontSize="15"
                    Text="🔍"
                    VerticalOptions="Center" />

                <Entry
                    x:Name="BuscaEntry"
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    FontSize="14"
                    Placeholder="Digite uma palavra-chave"
                    PlaceholderColor="#8A8A8A"
                    ReturnCommand="{Binding PesquisarCommand}"
                    ReturnType="Search"
                    Text="{Binding TextoBusca}"
                    TextColor="#1B1B1B" />
            </Grid>
        </dx:DXBorder>

        <!--  AGRUPAMENTO  -->
        <HorizontalStackLayout Grid.Row="2" Spacing="10">

            <dx:DXBorder
                Padding="14,8"
                BackgroundColor="{Binding AgruparPorConversa, Converter={StaticResource BoolToColorConverter}}"
                CornerRadius="14">
                <Grid>
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Por conversa"
                        TextColor="White" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AgruparConversaCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </dx:DXBorder>

            <dx:DXBorder
                Padding="14,8"
                BackgroundColor="{Binding AgruparPorData, Converter={StaticResource BoolToColorConverter}}"
                CornerRadius="14">
                <Grid>
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Por data"
                        TextColor="White" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AgruparDataCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </dx:DXBorder>
        </HorizontalStackLayout>

        <!--  RESULTADOS  -->
        <CollectionView
            Grid.Row="3"
            IsGrouped="True"
            ItemsSource="{Binding ResultadosAgrupados}"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <Grid>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="10"
                        VerticalOptions="Center">
                        <Label
                            FontSize="22"
                            HorizontalTextAlignment="Center"
                            Text="🔎" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="{Binding MensagemVazia}"
                            TextColor="#1B1B1B" />
                        <Label
                            FontSize="13"
                            HorizontalTextAlignment="Center"
                            Text="Pesquise por palavras que aparecem dentro das conversas."
                            TextColor="#6F6F6F" />
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:GrupoBuscaResultado">
                    <Label
                        Margin="0,8,0,8"
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="{Binding TituloGrupo}"
                        TextColor="#4B4B4B" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatBuscaResultado">
                    <Grid Margin="0,0,0,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference BuscaRoot}, Path=BindingContext.AbrirResultadoCommand}" CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <dx:DXBorder
                            Padding="14"
                            BackgroundColor="White"
                            CornerRadius="18">

                            <Grid
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="12"
                                RowDefinitions="Auto,Auto,Auto">

                                <dx:DXBorder
                                    Grid.RowSpan="3"
                                    BackgroundColor="#6D74E6"
                                    CornerRadius="5"
                                    HeightRequest="10"
                                    VerticalOptions="Center"
                                    WidthRequest="10" />

                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    Text="{Binding Titulo}"
                                    TextColor="#1B1B1B" />

                                <Label
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    FontSize="12"
                                    Text="{Binding DataMensagemTexto}"
                                    TextColor="#8A8A8A"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    FontSize="12"
                                    Text="{Binding OrigemTexto}"
                                    TextColor="#6D74E6" />

                                <Label
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    FontSize="12"
                                    LineBreakMode="WordWrap"
                                    MaxLines="3">
                                    <Label.FormattedText>
                                        <MultiBinding Converter="{StaticResource TextoBuscaHighlightConverter}">
                                            <Binding Path="Trecho" />
                                            <Binding Path="BindingContext.TextoBusca" Source="{x:Reference BuscaRoot}" />
                                        </MultiBinding>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </dx:DXBorder>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>