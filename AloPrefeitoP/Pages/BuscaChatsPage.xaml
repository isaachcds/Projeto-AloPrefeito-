<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.BuscaChatsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AloPrefeitoP.Models"
    x:Name="BuscaRoot"
    Title="Buscar conversas"
    BackgroundColor="#F5F5F7"
    Shell.NavBarIsVisible="False">

    <Grid
        Padding="20,18"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="14">

        <!--  TOPO  -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="12">
            <dx:DXBorder
                Padding="10"
                BackgroundColor="White"
                CornerRadius="14"
                HeightRequest="44"
                WidthRequest="44">
                <Grid>
                    <Label
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="←"
                        TextColor="#1B1B1B"
                        VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VoltarCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </dx:DXBorder>

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="22"
                Text="Buscar conversas"
                TextColor="#1B1B1B"
                VerticalOptions="Center" />
        </Grid>

        <!--  CAMPO DE BUSCA  -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10">

            <dx:DXBorder
                Grid.Column="0"
                Padding="14,10"
                BackgroundColor="White"
                CornerRadius="16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label
                        Grid.Column="0"
                        FontSize="15"
                        Text="🔍"
                        VerticalOptions="Center" />

                    <Entry
                        x:Name="BuscaEntry"
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        FontSize="14"
                        Placeholder="Digite uma palavra-chave"
                        PlaceholderColor="#8A8A8A"
                        ReturnCommand="{Binding PesquisarCommand}"
                        ReturnType="Search"
                        Text="{Binding TextoBusca}"
                        TextColor="#1B1B1B" />
                </Grid>
            </dx:DXBorder>

            <dx:DXBorder
                Grid.Column="1"
                Padding="14,10"
                BackgroundColor="#6D74E6"
                CornerRadius="16">
                <Grid>
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="Buscar"
                        TextColor="White"
                        VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PesquisarCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </dx:DXBorder>
        </Grid>

        <!--  RESULTADOS  -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Resultados}"
            SelectionMode="None"
            VerticalScrollBarVisibility="Never">

            <CollectionView.EmptyView>
                <Grid>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="10"
                        VerticalOptions="Center">
                        <Label
                            FontSize="22"
                            HorizontalTextAlignment="Center"
                            Text="🔎" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="{Binding MensagemVazia}"
                            TextColor="#1B1B1B" />
                        <Label
                            FontSize="13"
                            HorizontalTextAlignment="Center"
                            Text="Pesquise por palavras que aparecem dentro das conversas."
                            TextColor="#6F6F6F" />
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatBuscaResultado">
                    <Grid Margin="0,0,0,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference BuscaRoot}, Path=BindingContext.AbrirResultadoCommand}" CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <dx:DXBorder
                            Padding="14"
                            BackgroundColor="White"
                            CornerRadius="18">

                            <Grid
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="12"
                                RowDefinitions="Auto,Auto">

                                <dx:DXBorder
                                    Grid.RowSpan="2"
                                    BackgroundColor="#6D74E6"
                                    CornerRadius="5"
                                    HeightRequest="10"
                                    VerticalOptions="Center"
                                    WidthRequest="10" />

                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    Text="{Binding Titulo}"
                                    TextColor="#1B1B1B" />

                                <Label
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    FontSize="12"
                                    Text="{Binding UltimaDataTexto}"
                                    TextColor="#8A8A8A"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    FontSize="12"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="2"
                                    Text="{Binding Trecho}"
                                    TextColor="#6F6F6F" />
                            </Grid>
                        </dx:DXBorder>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>