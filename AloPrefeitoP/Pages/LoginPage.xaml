<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    BackgroundColor="#F3F3F3"
    BackgroundImageSource="iagestor360.jpeg">

    <Grid>
        <!--  CONTEÚDO  -->
        <ScrollView>
            <VerticalStackLayout Padding="30,20,30,24" Spacing="14">
                <!--  TOPO  -->
                <VerticalStackLayout
                    Margin="0,24,0,0"
                    HorizontalOptions="Center"
                    Spacing="4">

                    <Label
                        Margin="0,18,0,0"
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Acesse sua conta"
                        TextColor="Black" />
                </VerticalStackLayout>

                <!--  CARD LOGIN  -->
                <dx:DXBorder
                    Margin="0,10,0,0"
                    Padding="18"
                    BackgroundColor="#F4F4F4"
                    CornerRadius="10">

                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontSize="14"
                                Text="Email"
                                TextColor="#2A2A2A" />

                            <dx:DXBorder
                                Padding="12,8"
                                BackgroundColor="#EFEFEF"
                                BorderColor="#D6D6D6"
                                BorderThickness="1"
                                CornerRadius="8">

                                <Entry
                                    BackgroundColor="Transparent"
                                    Keyboard="Email"
                                    Placeholder="seuemail@exemplo.com"
                                    PlaceholderColor="#8C8C8C"
                                    Text="{Binding Email}"
                                    TextColor="#222222" />
                            </dx:DXBorder>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontSize="14"
                                Text="Senha"
                                TextColor="#2A2A2A" />

                            <Grid ColumnDefinitions="*,Auto">
                                <dx:DXBorder
                                    Grid.ColumnSpan="2"
                                    Padding="12,8"
                                    BackgroundColor="#EFEFEF"
                                    BorderColor="#D6D6D6"
                                    BorderThickness="1"
                                    CornerRadius="8">

                                    <Entry
                                        Margin="0,0,34,0"
                                        BackgroundColor="Transparent"
                                        IsPassword="{Binding SenhaVisivel, Converter={StaticResource InverseBoolConverter}}"
                                        Placeholder="Digite sua senha"
                                        PlaceholderColor="#8C8C8C"
                                        Text="{Binding Senha}"
                                        TextColor="#222222" />
                                </dx:DXBorder>

                                <ImageButton
                                    Grid.Column="1"
                                    Margin="0,0,10,0"
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    Command="{Binding AlternarSenhaCommand}"
                                    HeightRequest="22"
                                    HorizontalOptions="End"
                                    Source="{Binding SenhaVisivel, Converter={StaticResource PasswordEyeIconConverter}}"
                                    VerticalOptions="Center"
                                    WidthRequest="22" />
                            </Grid>
                        </VerticalStackLayout>

                        <Button
                            Margin="0,6,0,0"
                            BackgroundColor="#2F2F32"
                            Command="{Binding LoginCommand}"
                            CornerRadius="8"
                            HeightRequest="46"
                            Text="Entrar"
                            TextColor="White" />

                        <Button
                            Padding="0"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            Command="{Binding IrParaRecuperarSenhaCommand}"
                            HorizontalOptions="Start"
                            Text="Esqueci minha senha"
                            TextColor="#2A2A2A" />
                    </VerticalStackLayout>
                </dx:DXBorder>

                <!--  BIOMETRIA  -->
                <VerticalStackLayout Margin="0,0,0,8" Spacing="10">

                    <Border
                        Padding="16,0,10,0"
                        BackgroundColor="#8CC9E8"
                        HeightRequest="38"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="19" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontSize="14"
                                Text="Habilitar FaceID"
                                TextColor="Black"
                                VerticalOptions="Center" />

                            <Switch
                                Grid.Column="1"
                                HorizontalOptions="End"
                                IsToggled="{Binding HabilitarFaceId}"
                                OnColor="#111111"
                                Scale="0.8"
                                ThumbColor="Black"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="16,0,10,0"
                        BackgroundColor="#8CC9E8"
                        HeightRequest="38"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="19" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontSize="14"
                                Text="Habilitar Biometria"
                                TextColor="Black"
                                VerticalOptions="Center" />

                            <Switch
                                Grid.Column="1"
                                HorizontalOptions="End"
                                IsToggled="{Binding HabilitarBiometria}"
                                OnColor="#111111"
                                Scale="0.8"
                                ThumbColor="Black"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>