<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    BackgroundColor="White"
    BackgroundImageSource="iagestor360_2.png"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout
            Padding="30,0,30,0"
            HorizontalOptions="Center"
            Spacing="14"
            VerticalOptions="End">

            <!--  TEXTO SUPERIOR  -->
            <VerticalStackLayout HorizontalOptions="Center">
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="Acesse sua conta"
                    TextColor="#111111" />
            </VerticalStackLayout>

            <!--  CARD LOGIN  -->
            <dx:DXBorder
                Padding="16"
                BackgroundColor="#F7F7F7"
                CornerRadius="14"
                HorizontalOptions="Center"
                WidthRequest="285">

                <VerticalStackLayout Spacing="12">

                    <!--  EMAIL  -->
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="Email"
                            TextColor="#2A2A2A" />

                        <dx:DXBorder
                            Padding="12,6"
                            BackgroundColor="#EFEFEF"
                            BorderColor="#D9D9D9"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Entry
                                BackgroundColor="Transparent"
                                FontSize="13"
                                HeightRequest="40"
                                Keyboard="Email"
                                Placeholder="seuemail@exemplo.com"
                                PlaceholderColor="#9A9A9A"
                                Text="{Binding Email}"
                                TextColor="#222222" />
                        </dx:DXBorder>
                    </VerticalStackLayout>

                    <!--  SENHA  -->
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="Senha"
                            TextColor="#2A2A2A" />

                        <Grid ColumnDefinitions="*,Auto">
                            <dx:DXBorder
                                Grid.ColumnSpan="2"
                                Padding="12,6"
                                BackgroundColor="#EFEFEF"
                                BorderColor="#D9D9D9"
                                BorderThickness="1"
                                CornerRadius="8">

                                <Entry
                                    Margin="0,0,34,0"
                                    BackgroundColor="Transparent"
                                    FontSize="13"
                                    HeightRequest="40"
                                    IsPassword="{Binding SenhaVisivel, Converter={StaticResource InverseBoolConverter}}"
                                    Placeholder="Digite sua senha"
                                    PlaceholderColor="#9A9A9A"
                                    Text="{Binding Senha}"
                                    TextColor="#222222" />
                            </dx:DXBorder>

                            <Image
                                Grid.Column="1"
                                Margin="0,0,12,0"
                                HeightRequest="18"
                                HorizontalOptions="End"
                                Source="{Binding SenhaVisivel, Converter={StaticResource PasswordEyeIconConverter}}"
                                VerticalOptions="Center"
                                WidthRequest="18">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AlternarSenhaCommand}" />
                                </Image.GestureRecognizers>
                            </Image>
                        </Grid>
                    </VerticalStackLayout>

                    <!--  BOTÃO ENTRAR  -->
                    <Button
                        Margin="0,6,0,0"
                        BackgroundColor="#0D2E63"
                        Command="{Binding LoginCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="13"
                        HeightRequest="44"
                        Text="Entrar"
                        TextColor="White" />

                    <!--  ESQUECI SENHA  -->
                    <Button
                        Padding="0"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Command="{Binding IrParaRecuperarSenhaCommand}"
                        FontAttributes="Bold"
                        FontSize="11"
                        HorizontalOptions="Center"
                        Text="Esqueci minha senha"
                        TextColor="#4A4A4A" />
                </VerticalStackLayout>
            </dx:DXBorder>

            <!--  FACE ID  -->
            <Border
                Padding="14,0,10,0"
                BackgroundColor="#D5EFFB"
                HeightRequest="38"
                HorizontalOptions="Center"
                StrokeThickness="0"
                WidthRequest="285">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="19" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="11"
                        Text="Habilitar Face ID"
                        TextColor="#13314D"
                        VerticalOptions="Center" />

                    <Switch
                        Grid.Column="1"
                        HorizontalOptions="End"
                        IsToggled="{Binding HabilitarFaceId}"
                        OnColor="#0D2E63"
                        Scale="0.72"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </Grid>
</ContentPage>