<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    BackgroundColor="White"
    BackgroundImageSource="iagestor360_2.png"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout
            Padding="34,0,34,10"
            HorizontalOptions="Center"
            Spacing="10"
            TranslationY="-18"
            VerticalOptions="End">

            <Label
                FontAttributes="Bold"
                FontSize="14"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Acesse sua conta"
                TextColor="Black" />

            <dx:DXBorder
                Padding="14"
                BackgroundColor="#F4F4F4"
                CornerRadius="10"
                HorizontalOptions="Center"
                WidthRequest="250">

                <VerticalStackLayout Spacing="10">

                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontSize="12"
                            Text="Email"
                            TextColor="#2A2A2A" />

                        <dx:DXBorder
                            Padding="10,5"
                            BackgroundColor="#EFEFEF"
                            BorderColor="#D6D6D6"
                            BorderThickness="1"
                            CornerRadius="6">

                            <Entry
                                BackgroundColor="Transparent"
                                FontSize="12"
                                HeightRequest="34"
                                Keyboard="Email"
                                Placeholder="seuemail@exemplo.com"
                                PlaceholderColor="#8C8C8C"
                                Text="{Binding Email}"
                                TextColor="#222222" />
                        </dx:DXBorder>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontSize="12"
                            Text="Senha"
                            TextColor="#2A2A2A" />

                        <Grid ColumnDefinitions="*,Auto">
                            <dx:DXBorder
                                Grid.ColumnSpan="2"
                                Padding="10,5"
                                BackgroundColor="#EFEFEF"
                                BorderColor="#D6D6D6"
                                BorderThickness="1"
                                CornerRadius="6">

                                <Entry
                                    Margin="0,0,28,0"
                                    BackgroundColor="Transparent"
                                    FontSize="12"
                                    HeightRequest="34"
                                    IsPassword="{Binding SenhaVisivel, Converter={StaticResource InverseBoolConverter}}"
                                    Placeholder="Digite sua senha"
                                    PlaceholderColor="#8C8C8C"
                                    Text="{Binding Senha}"
                                    TextColor="#222222" />
                            </dx:DXBorder>

                            <ImageButton
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                Padding="0"
                                BackgroundColor="Transparent"
                                Command="{Binding AlternarSenhaCommand}"
                                HeightRequest="5"
                                HorizontalOptions="End"
                                Source="{Binding SenhaVisivel, Converter={StaticResource PasswordEyeIconConverter}}"
                                VerticalOptions="Center"
                                WidthRequest="5" />
                        </Grid>
                    </VerticalStackLayout>

                    <Button
                        Margin="0,4,0,0"
                        BackgroundColor="#2F2F32"
                        Command="{Binding LoginCommand}"
                        CornerRadius="6"
                        FontSize="12"
                        HeightRequest="38"
                        Text="Entrar"
                        TextColor="White" />

                    <Button
                        Padding="0"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Command="{Binding IrParaRecuperarSenhaCommand}"
                        FontSize="11"
                        HorizontalOptions="Start"
                        Text="Esqueci minha senha"
                        TextColor="#2A2A2A" />
                </VerticalStackLayout>
            </dx:DXBorder>

            <Border
                Padding="12,0,8,0"
                BackgroundColor="#8CC9E8"
                HeightRequest="30"
                HorizontalOptions="Center"
                StrokeThickness="0"
                WidthRequest="250">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        FontSize="11"
                        Text="Habilitar FaceID"
                        TextColor="Black"
                        VerticalOptions="Center" />

                    <Switch
                        Grid.Column="1"
                        HorizontalOptions="End"
                        IsToggled="{Binding HabilitarFaceId}"
                        OnColor="#111111"
                        Scale="0.65"
                        ThumbColor="Black"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!--<Border
                WidthRequest="250"
                Padding="12,0,8,0"
                BackgroundColor="#8CC9E8"
                HeightRequest="30"
                StrokeThickness="0"
                HorizontalOptions="Center">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        FontSize="11"
                        Text="Habilitar Biometria"
                        TextColor="Black"
                        VerticalOptions="Center" />

                    <Switch
                        Grid.Column="1"
                        HorizontalOptions="End"
                        IsToggled="{Binding HabilitarBiometria}"
                        OnColor="#111111"
                        Scale="0.65"
                        ThumbColor="Black"
                        VerticalOptions="Center" />
                </Grid>
            </Border>-->
        </VerticalStackLayout>
    </Grid>
</ContentPage>