<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.HistoricoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AloPrefeitoP.Models"
    x:Name="HistoricoRoot"
    Title="Histórico"
    BackgroundColor="#F4F4F4">

    <Grid
        Padding="18,24,18,18"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="18">

        <!--  TOPO  -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="12"
            VerticalOptions="Start">

            <Grid HeightRequest="44" WidthRequest="44">
                <dx:DXButton
                    BackgroundColor="Transparent"
                    ButtonType="ToolButton"
                    Command="{Binding VoltarCommand}"
                    HeightRequest="44"
                    Icon="arrow_left_icon.png"
                    IconColor="#1B1B1B"
                    WidthRequest="44" />
            </Grid>

            <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                VerticalOptions="Center">

                <Label
                    FontAttributes="Bold"
                    FontSize="24"
                    Text="Histórico"
                    TextColor="#1B1B1B" />

                <Label
                    FontSize="13"
                    LineBreakMode="WordWrap"
                    Text="Acesse conversas anteriores ou inicie um novo chat."
                    TextColor="#6F6F6F" />
            </VerticalStackLayout>
        </Grid>

        <!--  BOTÃO NOVO CHAT  -->
        <dx:DXBorder
            Grid.Row="1"
            Padding="0"
            BackgroundColor="#8EC1D8"
            CornerRadius="18">

            <Grid HeightRequest="56">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NovoChatCommand}" />
                </Grid.GestureRecognizers>

                <Grid
                    Padding="18,0"
                    ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">

                    <dx:DXBorder
                        Grid.Column="0"
                        BackgroundColor="#FFFFFF"
                        CornerRadius="12"
                        HeightRequest="28"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="28">

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Text="+"
                            TextColor="#8EC1D8"
                            VerticalOptions="Center"
                            VerticalTextAlignment="Center" />
                    </dx:DXBorder>

                    <Label
                        Grid.Column="1"
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="Novo chat"
                        TextColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Grid>
        </dx:DXBorder>

        <!--  LISTA  -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Chats}"
            SelectionMode="None"
            VerticalScrollBarVisibility="Never">

            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="24,60"
                    HorizontalOptions="Center"
                    Spacing="10"
                    VerticalOptions="Center">

                    <dx:DXBorder
                        Padding="18"
                        BackgroundColor="White"
                        BorderThickness="0"
                        CornerRadius="20">

                        <Label
                            FontSize="28"
                            HorizontalTextAlignment="Center"
                            Text="💬" />
                    </dx:DXBorder>

                    <Label
                        FontAttributes="Bold"
                        FontSize="17"
                        HorizontalTextAlignment="Center"
                        Text="Nenhuma conversa ainda"
                        TextColor="#1B1B1B" />

                    <Label
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"
                        Text="Quando você iniciar um chat, ele aparecerá aqui."
                        TextColor="#6F6F6F" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatResumo">
                    <Grid Margin="0,0,0,12">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference HistoricoRoot}, Path=BindingContext.AbrirChatCommand}" CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <dx:DXBorder
                            Padding="14"
                            BackgroundColor="White"
                            BorderThickness="0"
                            CornerRadius="18">

                            <Grid
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="12"
                                RowDefinitions="Auto,Auto">

                                <!--  indicador lateral  -->
                                <dx:DXBorder
                                    Grid.RowSpan="2"
                                    BackgroundColor="#8EC1D8"
                                    CornerRadius="6"
                                    HeightRequest="42"
                                    VerticalOptions="Center"
                                    WidthRequest="6" />

                                <!--  título  -->
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    Text="{Binding Titulo}"
                                    TextColor="#1B1B1B"
                                    VerticalOptions="Center" />

                                <!--  data + menu  -->
                                <HorizontalStackLayout
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Spacing="6"
                                    VerticalOptions="Center">

                                    <Label
                                        FontSize="12"
                                        Text="{Binding UltimaDataTexto}"
                                        TextColor="#8A8A8A"
                                        VerticalOptions="Center" />

                                    <ImageButton
                                        Padding="0"
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference HistoricoRoot}, Path=BindingContext.MostrarOpcoesCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="26"
                                        WidthRequest="26">
                                        <ImageButton.Source>
                                            <FontImageSource
                                                Glyph="⋮"
                                                Size="18"
                                                Color="#6F6F6F" />
                                        </ImageButton.Source>
                                    </ImageButton>
                                </HorizontalStackLayout>

                                <!--  subtítulo  -->
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    FontSize="12"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    Text="Toque para abrir esta conversa"
                                    TextColor="#6F6F6F" />
                            </Grid>
                        </dx:DXBorder>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>