<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AloPrefeitoP.Pages.RecuperarSenhaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    BackgroundColor="White"
    BackgroundImageSource="iagestor360_2.png"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout
            Padding="34,0,34,-104"
            HorizontalOptions="Center"
            Spacing="10"
            TranslationY="35"
            VerticalOptions="Center">

            <Label
                FontAttributes="Bold"
                FontSize="16"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Recuperar senha"
                TextColor="Black" />

            <dx:DXBorder
                Padding="14"
                BackgroundColor="#F4F4F4"
                CornerRadius="10"
                HorizontalOptions="Center"
                WidthRequest="250">

                <VerticalStackLayout Spacing="10">

                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontSize="12"
                            Text="Email"
                            TextColor="#2A2A2A" />

                        <dx:DXBorder
                            Padding="10,5"
                            BackgroundColor="#EFEFEF"
                            BorderColor="#D6D6D6"
                            BorderThickness="1"
                            CornerRadius="6">

                            <Entry
                                BackgroundColor="Transparent"
                                FontSize="12"
                                HeightRequest="34"
                                Keyboard="Email"
                                Placeholder="seuemail@exemplo.com"
                                PlaceholderColor="#8C8C8C"
                                Text="{Binding Email}"
                                TextColor="#222222" />
                        </dx:DXBorder>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button
                            Grid.Column="0"
                            BackgroundColor="Transparent"
                            BorderColor="#999999"
                            BorderWidth="1"
                            Command="{Binding CancelarCommand}"
                            CornerRadius="6"
                            FontSize="12"
                            HeightRequest="36"
                            Text="Cancelar"
                            TextColor="#333333" />

                        <Button
                            Grid.Column="1"
                            BackgroundColor="#2F2F32"
                            Command="{Binding EnviarCodigoCommand}"
                            CornerRadius="6"
                            FontSize="12"
                            HeightRequest="36"
                            Text="Enviar Código"
                            TextColor="White" />
                    </Grid>

                </VerticalStackLayout>
            </dx:DXBorder>
        </VerticalStackLayout>
    </Grid>
</ContentPage>